# Copy to .env and fill in your values
# Web API token — protects all /api/* endpoints (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
API_TOKEN=your_web_api_token_here
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Wallet targets for progress bars (optional); comma-separated for multiple
WALLET_TARGET=1000,5000
