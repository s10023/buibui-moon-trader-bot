# Copy to .env and fill in your values
# Web API token — protects all /api/* endpoints (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
API_TOKEN=your_web_api_token_here
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Wallet targets for progress bars (optional); comma-separated for multiple
WALLET_TARGET=1000,5000

# --- VPS deploy (systemd timers; see deploy/README.md) ---
# Market data source on the box (binance works from SG/MY — not geo-blocked)
DATA_SOURCE=binance
# XS executor mode for the daily timer: dry_run | testnet | live
EXEC_MODE=dry_run
# Optional fixed sizing capital for a capital-matched testnet A/B
# (set to your real account's equity on testnet; OMIT for live = real equity)
EXEC_CAPITAL=
# Optional extra executor flags, e.g. "--vol-target 0.10"
EXEC_EXTRA_ARGS=
# Binance Futures TESTNET keys (used when EXEC_MODE=testnet; throwaway, no real funds)
BINANCE_TESTNET_API_KEY=your_testnet_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_secret_here
# healthchecks.io dead-man's-switch ping URLs (create one check per job; leave
# empty to disable — but then a silently-missed run won't alert you)
HEALTHCHECKS_URL_SIGNAL=
HEALTHCHECKS_URL_XSMOM=
